# Anthropic API key — required for AI features
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Prisma Postgres connection string (provision at https://console.prisma.io/)
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=...
# The same URL is used for runtime queries, `prisma db push`, and seeding.
DATABASE_URL=

NEXT_PUBLIC_APP_NAME=CreatorAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
