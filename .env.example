# Anthropic API key — required for AI features
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Postgres connection string. Any provider works:
#   - Vercel Postgres: `vercel env pull .env.local` after attaching the DB
#   - Neon / Supabase / RDS: paste the postgres:// URL they give you
#   - Local Docker: postgres://postgres:pw@localhost:5432/postgres
DATABASE_URL=

# Workspace password — required. The single user signs in with this at /login.
APP_PASSWORD=

# Secret used to sign session cookies — required. At least 16 chars.
# Generate one with: openssl rand -base64 32
APP_SESSION_SECRET=

NEXT_PUBLIC_APP_NAME=CreatorAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
