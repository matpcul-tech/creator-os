# Anthropic API key — required for AI features
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Prisma Postgres connection string (provision at https://console.prisma.io/)
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=...
# The same URL is used for runtime queries, `prisma db push`, and seeding.
DATABASE_URL=

# Workspace password — required. The single user signs in with this at /login.
APP_PASSWORD=

# Secret used to sign session cookies — required. At least 16 chars.
# Generate one with: openssl rand -base64 32
APP_SESSION_SECRET=

NEXT_PUBLIC_APP_NAME=CreatorAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
